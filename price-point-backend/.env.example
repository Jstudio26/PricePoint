# Port server
PORT=8080

# MongoDB connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=<appName>

# JWT secret key (gunakan string acak yang kuat)
JWT_SECRET=ganti_dengan_secret_yang_kuat

# URL frontend untuk CORS
# Untuk lokal: http://localhost:3000
# Untuk production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000
